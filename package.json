{
  "name": "clawforge",
  "version": "1.0.0",
  "description": "ClawForge — Multi-agent orchestration for Raspberry Pi",
  "type": "module",
  "main": "dist/gateway/server.impl.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/gateway/server.impl.js",
    "start:pi": "node --max-old-space-size=512 --expose-gc dist/gateway/server.impl.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose \"src/**/*.clawforge.test.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.3",
    "js-yaml": "^4.1.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.5",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
